{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "artifacts/gestao/dist/public",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://api.uaus.com.br/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
